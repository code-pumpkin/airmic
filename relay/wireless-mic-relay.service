[Unit]
Description=Wireless Mic Input Relay
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/wireless-mic-relay
ExecStart=/usr/bin/node relay.js
Restart=always
RestartSec=5
Environment=PORT=4001
# Uncomment to override cert directory:
# Environment=CERT_DIR=/etc/letsencrypt/live/yourdomain.com

[Install]
WantedBy=multi-user.target
